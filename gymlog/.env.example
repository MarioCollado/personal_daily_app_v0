# Copia este archivo como .env.local y rellena tus credenciales de Supabase
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY_AQUI

# Anthropic API key - necesaria para recomendaciones reales de recetas
# Obtener en: https://console.anthropic.com/
# Sin esta key la app funciona en modo preview con recetas de ejemplo
ANTHROPIC_API_KEY=
